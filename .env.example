# ═══════════════════════════════════════════
# BANCO DE DADOS
# ═══════════════════════════════════════════
POSTGRES_USER=cardapio_user
POSTGRES_PASSWORD=cardapio_pass
POSTGRES_DB=cardapio_dev
DATABASE_URL="postgresql://cardapio_user:cardapio_pass@localhost:5432/cardapio_dev"

# ═══════════════════════════════════════════
# JWT / AUTH
# ═══════════════════════════════════════════
JWT_SECRET=sua-chave-secreta-aqui-troque-em-producao
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ═══════════════════════════════════════════
# WHATSAPP BUSINESS API (Meta Cloud API)
# ═══════════════════════════════════════════
WHATSAPP_API_TOKEN=seu-token-aqui
WHATSAPP_PHONE_NUMBER_ID=seu-phone-number-id
WHATSAPP_VERIFY_TOKEN=seu-verify-token-webhook

# ═══════════════════════════════════════════
# OPENAI
# ═══════════════════════════════════════════
OPENAI_API_KEY=sk-sua-chave-openai

# ═══════════════════════════════════════════
# N8N
# ═══════════════════════════════════════════
N8N_USER=admin
N8N_PASSWORD=admin123
N8N_WEBHOOK_URL=http://localhost:5678

# ═══════════════════════════════════════════
# PGADMIN
# ═══════════════════════════════════════════
PGADMIN_EMAIL=admin@cardapio.dev
PGADMIN_PASSWORD=admin123

# ═══════════════════════════════════════════
# REDIS
# ═══════════════════════════════════════════
REDIS_URL=redis://localhost:6379

# ═══════════════════════════════════════════
# STORAGE (Cloudflare R2)
# ═══════════════════════════════════════════
R2_ACCOUNT_ID=seu-account-id
R2_ACCESS_KEY_ID=sua-access-key
R2_SECRET_ACCESS_KEY=sua-secret-key
R2_BUCKET_NAME=cardapio-images
R2_PUBLIC_URL=https://cdn.seudominio.com

# ═══════════════════════════════════════════
# FRONTEND
# ═══════════════════════════════════════════
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ═══════════════════════════════════════════
# STRIPE (Pagamentos SaaS)
# ═══════════════════════════════════════════
STRIPE_SECRET_KEY=sk_test_sua-chave
STRIPE_WEBHOOK_SECRET=whsec_sua-chave
STRIPE_PRICE_PRO=price_pro-id
STRIPE_PRICE_ENTERPRISE=price_enterprise-id
